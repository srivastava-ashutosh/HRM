{
  "name": "indianic-hrm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server": "cd server && node server.js",
    "client": "cd client && npx react-scripts start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "cd server && node seeds/seed.js",
    "seed-roles": "cd server && node seeds/seedRoles.js",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:install": "cd e2e && npx playwright install --with-deps"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
